APP_NAME=Beddrop
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.beddrop.ru
FRONTEND_URL=https://beddrop.ru

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CORS_ALLOWED_ORIGINS=https://beddrop.ru
AUTH_REFRESH_TOKEN_TTL=43200
AUTH_REFRESH_TOKEN_LENGTH=80
AUTH_REFRESH_COOKIE_NAME=laravel_refresh_token
AUTH_REFRESH_COOKIE_DOMAIN=null
AUTH_REFRESH_COOKIE_PATH=/api/v1/auth
AUTH_REFRESH_COOKIE_SECURE=true
AUTH_REFRESH_COOKIE_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@beddrop.ru
MAIL_FROM_NAME="${APP_NAME}"

DADATA_API_KEY=
DADATA_SECRET_KEY=
VALHALLA_URL=http://valhalla:8002

JWT_SECRET=

SCRIBE_API_VERSION=1.0.0
SCRIBE_AUTH_KEY=
SCRIBE_DOCS_AUTH=true
SCRIBE_RESPONSE_CALLS=false

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://beddrop.ru/orders
YOOKASSA_WEBHOOK_URL=https://api.beddrop.ru/api/v1/payments/yookassa/webhook
YOOKASSA_CAPTURE=true
YOOKASSA_CURRENCY=RUB

NUXT_PUBLIC_API_BASE=https://api.beddrop.ru/api/v1
NUXT_PUBLIC_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
NUXT_PUBLIC_MAP_TILE_ATTRIBUTION="© OpenStreetMap contributors"
