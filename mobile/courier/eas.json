{
  "cli": { "version": ">= 16.0.1", "appVersionSource": "local" },
  "build": {
    "apk": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_BASE": "https://api.beddrop.ru/api/v1"
      }
    },
    "preview": {
      "android": { "buildType": "apk" },
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_BASE": "https://api.beddrop.ru/api/v1"
      }
    },
    "production": {
      "android": { "buildType": "app-bundle" },
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_BASE": "https://api.beddrop.ru/api/v1"
      }
    }
  }
}
